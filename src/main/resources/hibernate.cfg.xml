<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <!-- Настройки подключения к БД H2 -->
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:./spacetravel</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>

        <!-- Отображение SQL в консоли для отладки -->
        <property name="show_sql">true</property>
        <property name="format_sql">true</property>

        <!-- Регистрация сущностей -->
        <mapping class="com.spacetravel.model.Client"/>
        <mapping class="com.spacetravel.model.Planet"/>
    </session-factory>
</hibernate-configuration>